{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Gene Regulatory Systems",
  "version": "0.1.0",
  "identifier": "jl.generegulatorysystems.grs",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": { "script": "npm run dev", "cwd": "../frontend" },
    "beforeBuildCommand": { "script": "npm run build", "cwd": "../frontend" }
  },
  "app": {
    "windows": [
      {
        "title": "Gene Regulatory Systems",
        "width": 1920,
        "height": 1080,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../backend/run.jl": "server/run.jl",
      "../backend/Project.toml": "server/Project.toml",
      "../backend/Manifest.toml": "server/Manifest.toml",
      "../backend/src/*": "server/src/",
      "../backend/src/simulation/*": "server/src/simulation/",
      "../backend/src/schedule/*": "server/src/schedule/",
      "../backend/examples/*": "server/examples/"
    }
  }
}
