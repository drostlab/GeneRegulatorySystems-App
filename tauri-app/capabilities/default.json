{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:menu:default",
    "dialog:default",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-write-text-file",
    "fs:allow-write-file",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**" }]
    }
  ]
}
