{
    "repressilator": {
        "genes": [
            {
                "$": ["defaults", "gene"],
                "activation": [{"from": "gene_1", "at": 2.0}],
                "repression": [{"from": "gene_3", "at": 4.0}],
                "name": "gene_1"
            },
            {
                "$": ["defaults", "gene"],
                "activation": [{"from": "gene_2", "at": 2.0}],
                "repression": [{"from": "gene_1", "at": 4.0}],
                "name": "gene_2"
            },
            {
                "$": ["defaults", "gene"],
                "activation": [{"from": "gene_3", "at": 2.0}],
                "repression": [{"from": "gene_2", "at": 4.0}],
                "name": "gene_3"
            }
        ]
    },
    "step": {
        "dark_model": {"{regulation/v1}": {"$": "repressilator"}},
        "light_model": {"{regulation/v1}": {
            "$": "repressilator",
            "reactions": [{"from": ["gene_2"], "rate": 0.001, "to": []}]
        }},
        "into": "{channels}",
        "step": {
            "dark_model": {"{regulation/v1}": {"$": "repressilator"}},
            "light_model": {"{regulation/v1}": {
                "$": "repressilator",
                "reactions": [{"from": ["gene_2"], "rate": 0.001, "to": []}]
            }},
            "into": "{channels}",
            "seed": "${rootseed}-repressilator",
            "step": [
                {"{add}": {
                    "$": ["defaults", "bootstrap"],
                    "gene_1.proteins": 100
                }},
                {"to": 455000.0, "step": [
                    {"channel": "dark", "step": {"to": 60000.0, "step": 100.0, "do": {"$": "dark_model"}}},
                    {"channel": "light", "step": {"to": 5000.0, "step": 100.0, "do": {"$": "light_model"}}}
                ]},
                {
                    "branch": true,
                    "each": {"length": 5},
                    "step": {"to": 455000.0, "step": [
                        {"channel": "dark", "step": {"to": 60000.0, "step": 100.0, "do": {"$": "dark_model"}}},
                        {"channel": "light", "step": {"to": 5000.0, "step": 100.0, "do": {"$": "light_model"}}}
                    ]}
                }
            ]
        }
    }
}
